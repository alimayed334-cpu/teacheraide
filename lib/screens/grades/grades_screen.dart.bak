class _StudentGradeItem extends StatelessWidget {
  final GradeModel grade;
  final double maxScore;

  const _StudentGradeItem({
    required this.grade,
    required this.maxScore,
  });

  @override
  Widget build(BuildContext context) {
    final percentage = (grade.score / maxScore) * 100;
    Color gradeColor = AppTheme.successColor;
    if (percentage < 60) {
      gradeColor = AppTheme.errorColor;
    } else if (percentage < 75) {
      gradeColor = AppTheme.warningColor;
    }

    return Card(
      margin: const EdgeInsets.only(bottom: 8),
      child: ListTile(
        leading: CircleAvatar(
          backgroundColor: gradeColor.withOpacity(0.1),
          child: Text(
            grade.score.toString(),
            style: TextStyle(
              color: gradeColor,
              fontWeight: FontWeight.bold,
            ),
          ),
        ),
        title: Text(grade.studentName),
        subtitle: Text('${percentage.toStringAsFixed(1)}%'),
        trailing: Row(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text(
              '${grade.score}/${maxScore.toInt()}',
              style: TextStyle(
                fontWeight: FontWeight.bold,
                color: gradeColor,
              ),
            ),
            const SizedBox(width: 8),
            PopupMenuButton(
              itemBuilder: (context) => [
                const PopupMenuItem(
                  value: 'edit',
                  child: Row(
                    children: [
                      Icon(Icons.edit, size: 20),
                      SizedBox(width: 8),
                      Text('تعديل'),
                    ],
                  ),
                ),
                const PopupMenuItem(
                  value: 'delete',
                  child: Row(
                    children: [
                      Icon(Icons.delete, size: 20, color: AppTheme.errorColor),
                      SizedBox(width: 8),
                      Text('حذف', style: TextStyle(color: AppTheme.errorColor)),
                    ],
                  ),
                ),
              ],
              onSelected: (value) {
                if (value == 'edit') {
                  // TODO: تعديل درجة الطالب
                } else if (value == 'delete') {
                  // TODO: حذف درجة الطالب
                }
              },
            ),
          ],
        ),
      ),
    );
  }
}

class _AddGradeDialog extends StatefulWidget {
  final GradeModel exam;
  final ClassModel classModel;
  final VoidCallback onSave;

  const _AddGradeDialog({
    required this.exam,
    required this.classModel,
    required this.onSave,
  });

  @override
  State<_AddGradeDialog> createState() => _AddGradeDialogState();
}

class _AddGradeDialogState extends State<_AddGradeDialog> {
  final _formKey = GlobalKey<FormState>();
  StudentModel? _selectedStudent;
  late final TextEditingController _scoreController;

  @override
  void initState() {
    super.initState();
    _scoreController = TextEditingController();
  }

  @override
  void dispose() {
    _scoreController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return AlertDialog(
      title: const Text('إضافة درجة طالب'),
      content: SizedBox(
        width: double.maxFinite,
        child: Form(
          key: _formKey,
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              Consumer<StudentProvider>(
                builder: (context, studentProvider, child) {
                  final students = studentProvider.students
                      .where((s) => s.classId == widget.classModel.id)
                      .toList();

                  if (students.isEmpty) {
                    return const Text('لا يوجد طلاب في هذا الفصل');
                  }

                  return DropdownButtonFormField<StudentModel>(
                    value: _selectedStudent,
                    decoration: const InputDecoration(
                      labelText: 'اختر الطالب',
                      hintText: 'اختر الطالب',
                    ),
                    items: students.map((student) {
                      return DropdownMenuItem(
                        value: student,
                        child: Text(student.name),
                      );
                    }).toList(),
                    onChanged: (value) {
                      setState(() {
                        _selectedStudent = value;
                      });
                    },
                    validator: (value) {
                      if (value == null) {
                        return 'يرجى اختيار الطالب';
                      }
                      return null;
                    },
                  );
                },
              ),
              const SizedBox(height: 16),
              TextFormField(
                controller: _scoreController,
                decoration: InputDecoration(
                  labelText: 'الدرجة',
                  hintText: 'أدخل درجة الطالب (0 - ${widget.exam.maxScore.toInt()})',
                ),
                keyboardType: TextInputType.number,
                validator: (value) {
                  if (value == null || value.isEmpty) {
                    return 'يرجى إدخال الدرجة';
                  }
                  final score = double.tryParse(value);
                  if (score == null || score < 0 || score > widget.exam.maxScore) {
                    return 'يرجى إدخال درجة صحيحة بين 0 و ${widget.exam.maxScore.toInt()}';
                  }
                  return null;
                },
              ),
            ],
          ),
        ),
      ),
      actions: [
        TextButton(
          onPressed: () => Navigator.pop(context),
          child: const Text('إلغاء'),
        ),
        Consumer<GradeProvider>(
          builder: (context, gradeProvider, child) {
            return ElevatedButton(
              onPressed: gradeProvider.isLoading ? null : () async {
                if (_formKey.currentState!.validate() && _selectedStudent != null) {
                  final success = await gradeProvider.addStudentGrade(
                    widget.exam.id!,
                    _selectedStudent!.id!,
                    _selectedStudent!.name,
                    double.parse(_scoreController.text.trim()),
                  );

                  if (success && context.mounted) {
                    Navigator.pop(context);
                    widget.onSave();
                    ScaffoldMessenger.of(context).showSnackBar(
                      const SnackBar(content: Text('تم إضافة الدرجة بنجاح')),
                    );
                  }
                }
              },
              child: gradeProvider.isLoading
                  ? const SizedBox(
                      width: 16,
                      height: 16,
                      child: CircularProgressIndicator(strokeWidth: 2),
                    )
                  : const Text('إضافة'),
            );
          },
        ),
      ],
    );
  }
}

class StudentGradesScreen extends StatelessWidget {
  final StudentModel student;
  final ClassModel classModel;

  const StudentGradesScreen({
    super.key,
    required this.student,
    required this.classModel,
  });

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text('درجات ${student.name}'),
      ),
      body: Consumer<GradeProvider>(
        builder: (context, gradeProvider, child) {
          final grades = gradeProvider.getGradesByStudent(student.id!);

          if (grades.isEmpty) {
            return const Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Icon(
                    Icons.grade,
                    size: 64,
                    color: AppTheme.textSecondary,
                  ),
                  SizedBox(height: 16),
                  Text(
                    'لا توجد درجات مسجلة',
                    style: TextStyle(
                      fontSize: 18,
                      color: AppTheme.textSecondary,
                    ),
                  ),
                ],
              ),
            );
          }

          final average = grades.map((g) => g.score).reduce((a, b) => a + b) / grades.length;

          return Column(
            children: [
              // ملخص الدرجات
              Container(
                padding: const EdgeInsets.all(16),
                color: AppTheme.backgroundColor,
                child: Row(
                  mainAxisAlignment: MainAxisAlignment.spaceAround,
                  children: [
                    _GradeSummary(
                      label: 'المعدل',
                      value: average.toStringAsFixed(1),
                      color: _getGradeColor(average),
                    ),
                    _GradeSummary(
                      label: 'عدد الاختبارات',
                      value: grades.length.toString(),
                      color: AppTheme.primaryColor,
                    ),
                    _GradeSummary(
                      label: 'أعلى درجة',
                      value: grades.map((g) => g.score).reduce((a, b) => a > b ? a : b).toString(),
                      color: AppTheme.successColor,
                    ),
                    _GradeSummary(
                      label: 'أقل درجة',
                      value: grades.map((g) => g.score).reduce((a, b) => a < b ? a : b).toString(),
                      color: AppTheme.errorColor,
                    ),
                  ],
                ),
              ),
              
              // قائمة الدرجات
              Expanded(
                child: ListView.builder(
                  padding: const EdgeInsets.all(16),
                  itemCount: grades.length,
                  itemBuilder: (context, index) {
                    final grade = grades[index];
                    return _GradeItem(grade: grade);
                  },
                ),
              ),
            ],
          );
        },
      ),
    );
  }

  Color _getGradeColor(double grade) {
    if (grade >= 75) return AppTheme.successColor;
    if (grade >= 60) return AppTheme.warningColor;
    return AppTheme.errorColor;
  }
}

class SubjectGradesScreen extends StatelessWidget {
  final String subject;
  final ClassModel classModel;

  const SubjectGradesScreen({
    super.key,
    required this.subject,
    required this.classModel,
  });

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text('درجات مادة $subject'),
      ),
      body: Consumer<GradeProvider>(
        builder: (context, gradeProvider, child) {
          final grades = gradeProvider.getGradesBySubject(classModel.id!, subject);

          if (grades.isEmpty) {
            return const Center(
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Icon(
                    Icons.subject,
                    size: 64,
                    color: AppTheme.textSecondary,
                  ),
                  SizedBox(height: 16),
                  Text(
                    'لا توجد درجات مسجلة لهذه المادة',
                    style: TextStyle(
                      fontSize: 18,
                      color: AppTheme.textSecondary,
                    ),
                  ),
                ],
              ),
            );
          }

          return ListView.builder(
            padding: const EdgeInsets.all(16),
            itemCount: grades.length,
            itemBuilder: (context, index) {
              final grade = grades[index];
              return _GradeItem(grade: grade);
            },
          );
        },
      ),
    );
  }
}

class _GradeSummary extends StatelessWidget {
  final String label;
  final String value;
  final Color color;

  const _GradeSummary({
    required this.label,
    required this.value,
    required this.color,
  });

  @override
  Widget build(BuildContext context) {
    return Column(
      children: [
        Text(
          value,
          style: TextStyle(
            fontSize: 20,
            fontWeight: FontWeight.bold,
            color: color,
          ),
        ),
        Text(
          label,
          style: const TextStyle(
            fontSize: 12,
            color: AppTheme.textSecondary,
          ),
        ),
      ],
    );
  }
}

class _GradeItem extends StatelessWidget {
  final GradeModel grade;

  const _GradeItem({required this.grade});

  @override
  Widget build(BuildContext context) {
    Color gradeColor = AppTheme.successColor;
    if (grade.score < 60) {
      gradeColor = AppTheme.errorColor;
    } else if (grade.score < 75) {
      gradeColor = AppTheme.warningColor;
    }

    return Card(
      margin: const EdgeInsets.only(bottom: 8),
      child: ListTile(
        leading: CircleAvatar(
          backgroundColor: gradeColor.withOpacity(0.1),
          child: Text(
            grade.score.toString(),
            style: TextStyle(
              color: gradeColor,
              fontWeight: FontWeight.bold,
            ),
          ),
        ),
        title: Text(grade.examName),
        subtitle: Text('${grade.subject} - ${grade.examDate.day}/${grade.examDate.month}/${grade.examDate.year}'),
        trailing: Text(
          '${grade.score}/${grade.maxScore.toInt()}',
          style: TextStyle(
            fontWeight: FontWeight.bold,
            color: gradeColor,
          ),
        ),
      ),
    );
  }
}
