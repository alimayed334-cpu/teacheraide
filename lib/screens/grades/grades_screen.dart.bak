import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import '../../providers/grade_provider.dart';
import '../../providers/class_provider.dart';
import '../../providers/student_provider.dart';
import '../../theme/app_theme.dart';
import '../../models/grade_model.dart';
import '../../models/class_model.dart';
import '../../models/student_model.dart';

class GradesScreen extends StatefulWidget {
  const GradesScreen({super.key});

  @override
  State<GradesScreen> createState() => _GradesScreenState();
}

class _GradesScreenState extends State<GradesScreen> {
  ClassModel? _selectedClass;
  String _selectedView = 'exams'; // exams, students, subjects

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('إدارة الدرجات والاختبارات'),
        actions: [
          PopupMenuButton<String>(
            onSelected: (value) {
              setState(() {
                _selectedView = value;
              });
            },
            itemBuilder: (context) => [
              const PopupMenuItem(
                value: 'exams',
                child: Row(
                  children: [
                    Icon(Icons.quiz, size: 20),
                    SizedBox(width: 8),
                    Text('الاختبارات'),
                  ],
                ),
              ),
              const PopupMenuItem(
                value: 'students',
                child: Row(
                  children: [
                    Icon(Icons.people, size: 20),
                    SizedBox(width: 8),
                    Text('الطلاب'),
                  ],
                ),
              ),
              const PopupMenuItem(
                value: 'subjects',
                child: Row(
                  children: [
                    Icon(Icons.subject, size: 20),
                    SizedBox(width: 8),
                    Text('المواد'),
                  ],
                ),
              ),
            ],
          ),
        ],
      ),
      body: Column(
        children: [
          // اختيار الفصل
          Container(
            padding: const EdgeInsets.all(16),
            color: AppTheme.backgroundColor,
            child: InkWell(
              onTap: () => _showClassSelector(context),
              child: Container(
                padding: const EdgeInsets.all(12),
                decoration: BoxDecoration(
                  border: Border.all(color: AppTheme.primaryColor),
                  borderRadius: BorderRadius.circular(8),
                ),
                child: Row(
                  children: [
                    Icon(Icons.class_, color: AppTheme.primaryColor),
                    const SizedBox(width: 8),
                    Expanded(
                      child: Text(
                        _selectedClass?.name ?? 'اختر الفصل',
                        style: TextStyle(
                          color: _selectedClass != null 
                              ? AppTheme.primaryColor 
                              : AppTheme.textSecondary,
                        ),
                      ),
                    ),
                    Icon(
                      Icons.arrow_drop_down,
                      color: AppTheme.primaryColor,
                    ),
                  ],
                ),
              ),
            ),
          ),
          
          // المحتوى الرئيسي
          Expanded(
            child: _selectedClass == null
                ? const Center(
                    child: Column(
                      mainAxisAlignment: MainAxisAlignment.center,
                      children: [
                        Icon(
                          Icons.quiz,
                          size: 64,
                          color: AppTheme.textSecondary,
                        ),
                        SizedBox(height: 16),
                        Text(
                          'اختر الفصل لعرض الدرجات والاختبارات',
                          style: TextStyle(
                            fontSize: 18,
                            color: AppTheme.textSecondary,
                          ),
                        ),
                      ],
                    ),
                  )
                : _buildContentView(),
          ),
        ],
      ),
      floatingActionButton: _selectedClass != null
          ? FloatingActionButton(
              onPressed: () => _showAddExamDialog(context),
              child: const Icon(Icons.add),
            )
          : null,
    );
  }

  Widget _buildContentView() {
    switch (_selectedView) {
      case 'exams':
        return _ExamsView(classModel: _selectedClass!);
      case 'students':
        return _StudentsGradesView(classModel: _selectedClass!);
      case 'subjects':
        return _SubjectsGradesView(classModel: _selectedClass!);
      default:
        return _ExamsView(classModel: _selectedClass!);
    }
  }

  void _showClassSelector(BuildContext context) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('اختر الفصل'),
        content: Consumer<ClassProvider>(
          builder: (context, classProvider, child) {
            if (classProvider.classes.isEmpty) {
              return const Text('لا توجد فصول متاحة');
            }

            return Column(
              mainAxisSize: MainAxisSize.min,
              children: classProvider.classes.map((classModel) => ListTile(
                title: Text(classModel.name),
                subtitle: Text(classModel.subject),
                onTap: () {
                  setState(() {
                    _selectedClass = classModel;
                  });
                  Navigator.pop(context);
                  _loadGrades();
                },
              )).toList(),
            );
          },
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('إلغاء'),
          ),
        ],
      ),
    );
  }

  void _loadGrades() {
    if (_selectedClass != null) {
      Provider.of<GradeProvider>(context, listen: false)
          .loadGradesByClass(_selectedClass!.id!);
    }
  }

  void _showAddExamDialog(BuildContext context) {
    showDialog(
      context: context,
      builder: (context) => _AddExamDialog(
        classModel: _selectedClass!,
        onSave: () => _loadGrades(),
      ),
    );
  }
}

class _ExamsView extends StatelessWidget {
  final ClassModel classModel;

  const _ExamsView({required this.classModel});

  @override
  Widget build(BuildContext context) {
    return Consumer<GradeProvider>(
      builder: (context, gradeProvider, child) {
        if (gradeProvider.isLoading) {
          return const Center(
            child: CircularProgressIndicator(),
          );
        }

        final exams = gradeProvider.getExamsByClass(classModel.id!);

        if (exams.isEmpty) {
          return Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                const Icon(
                  Icons.quiz,
                  size: 64,
                  color: AppTheme.textSecondary,
                ),
                const SizedBox(height: 16),
                const Text(
                  'لا توجد اختبارات',
                  style: TextStyle(
                    fontSize: 18,
                    color: AppTheme.textSecondary,
                  ),
                ),
                const SizedBox(height: 8),
                const Text(
                  'ابدأ بإضافة اختبار جديد',
                  style: TextStyle(
                    color: AppTheme.textSecondary,
                  ),
                ),
                const SizedBox(height: 16),
                ElevatedButton.icon(
                  onPressed: () => _showAddExamDialog(context),
                  icon: const Icon(Icons.add),
                  label: const Text('إضافة اختبار'),
                ),
              ],
            ),
          );
        }

        return ListView.builder(
          padding: const EdgeInsets.all(16),
          itemCount: exams.length,
          itemBuilder: (context, index) {
            final exam = exams[index];
            return _ExamCard(
              exam: exam,
              onTap: () => _showExamDetails(context, exam),
              onEdit: () => _showEditExamDialog(context, exam),
              onDelete: () => _showDeleteConfirmation(context, exam),
            );
          },
        );
      },
    );
  }

  void _showAddExamDialog(BuildContext context) {
    showDialog(
      context: context,
      builder: (context) => _AddExamDialog(
        classModel: classModel,
        onSave: () {
          Provider.of<GradeProvider>(context, listen: false)
              .loadGradesByClass(classModel.id!);
        },
      ),
    );
  }

  void _showEditExamDialog(BuildContext context, GradeModel exam) {
    showDialog(
      context: context,
      builder: (context) => _AddExamDialog(
        classModel: classModel,
        exam: exam,
        onSave: () {
          Provider.of<GradeProvider>(context, listen: false)
              .loadGradesByClass(classModel.id!);
        },
      ),
    );
  }

  void _showExamDetails(BuildContext context, GradeModel exam) {
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => ExamDetailsScreen(exam: exam, classModel: classModel),
      ),
    );
  }

  void _showDeleteConfirmation(BuildContext context, GradeModel exam) {
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: const Text('تأكيد الحذف'),
        content: Text('هل أنت متأكد من حذف اختبار "${exam.examName}"؟\nسيتم حذف جميع الدرجات المرتبطة به.'),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('إلغاء'),
          ),
          TextButton(
            onPressed: () async {
              Navigator.pop(context);
              final gradeProvider = Provider.of<GradeProvider>(context, listen: false);
              final success = await gradeProvider.deleteExam(exam.id!);
              if (success && context.mounted) {
                ScaffoldMessenger.of(context).showSnackBar(
                  const SnackBar(content: Text('تم حذف الاختبار بنجاح')),
                );
              }
            },
            style: TextButton.styleFrom(foregroundColor: AppTheme.errorColor),
            child: const Text('حذف'),
          ),
        ],
      ),
    );
  }
}

class _StudentsGradesView extends StatelessWidget {
  final ClassModel classModel;

  const _StudentsGradesView({required this.classModel});

  @override
  Widget build(BuildContext context) {
    return Consumer2<StudentProvider, GradeProvider>(
      builder: (context, studentProvider, gradeProvider, child) {
        if (studentProvider.isLoading) {
          return const Center(
            child: CircularProgressIndicator(),
          );
        }

        final students = studentProvider.students
            .where((s) => s.classId == classModel.id)
            .toList();

        if (students.isEmpty) {
          return const Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Icon(
                  Icons.people,
                  size: 64,
                  color: AppTheme.textSecondary,
                ),
                SizedBox(height: 16),
                Text(
                  'لا يوجد طلاب في هذا الفصل',
                  style: TextStyle(
                    fontSize: 18,
                    color: AppTheme.textSecondary,
                  ),
                ),
              ],
            ),
          );
        }

        return ListView.builder(
          padding: const EdgeInsets.all(16),
          itemCount: students.length,
          itemBuilder: (context, index) {
            final student = students[index];
            final grades = gradeProvider.getGradesByStudent(student.id!);
            final average = grades.isNotEmpty
                ? grades.map((g) => g.score).reduce((a, b) => a + b) / grades.length
                : 0.0;

            return _StudentGradeCard(
              student: student,
              average: average,
              gradesCount: grades.length,
              onTap: () => _showStudentGrades(context, student),
            );
          },
        );
      },
    );
  }

  void _showStudentGrades(BuildContext context, StudentModel student) {
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => StudentGradesScreen(
          student: student,
          classModel: classModel,
        ),
      ),
    );
  }
}

class _SubjectsGradesView extends StatelessWidget {
  final ClassModel classModel;

  const _SubjectsGradesView({required this.classModel});

  @override
  Widget build(BuildContext context) {
    return Consumer<GradeProvider>(
      builder: (context, gradeProvider, child) {
        if (gradeProvider.isLoading) {
          return const Center(
            child: CircularProgressIndicator(),
          );
        }

        final subjects = gradeProvider.getSubjectsByClass(classModel.id!);

        if (subjects.isEmpty) {
          return const Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Icon(
                  Icons.subject,
                  size: 64,
                  color: AppTheme.textSecondary,
                ),
                SizedBox(height: 16),
                Text(
                  'لا توجد مواد دراسية',
                  style: TextStyle(
                    fontSize: 18,
                    color: AppTheme.textSecondary,
                  ),
                ),
              ],
            ),
          );
        }

        return ListView.builder(
          padding: const EdgeInsets.all(16),
          itemCount: subjects.length,
          itemBuilder: (context, index) {
            final subject = subjects[index];
            final grades = gradeProvider.getGradesBySubject(classModel.id!, subject);
            final average = grades.isNotEmpty
                ? grades.map((g) => g.score).reduce((a, b) => a + b) / grades.length
                : 0.0;

            return _SubjectGradeCard(
              subject: subject,
              average: average,
              gradesCount: grades.length,
              onTap: () => _showSubjectGrades(context, subject),
            );
          },
        );
      },
    );
  }

  void _showSubjectGrades(BuildContext context, String subject) {
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => SubjectGradesScreen(
          subject: subject,
          classModel: classModel,
        ),
      ),
    );
  }
}

class _ExamCard extends StatelessWidget {
  final GradeModel exam;
  final VoidCallback onTap;
  final VoidCallback onEdit;
  final VoidCallback onDelete;

  const _ExamCard({
    required this.exam,
    required this.onTap,
    required this.onEdit,
    required this.onDelete,
  });

  @override
  Widget build(BuildContext context) {
    return Card(
      margin: const EdgeInsets.only(bottom: 12),
      child: InkWell(
        onTap: onTap,
        borderRadius: BorderRadius.circular(16),
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Row(
                children: [
                  Container(
                    width: 50,
                    height: 50,
                    decoration: BoxDecoration(
                      color: AppTheme.primaryColor.withOpacity(0.1),
                      borderRadius: BorderRadius.circular(12),
                    ),
                    child: const Icon(
                      Icons.quiz,
                      color: AppTheme.primaryColor,
                      size: 24,
                    ),
                  ),
                  const SizedBox(width: 12),
                  Expanded(
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          exam.examName,
                          style: const TextStyle(
                            fontSize: 18,
                            fontWeight: FontWeight.bold,
                          ),
                        ),
                        const SizedBox(height: 4),
                        Text(
                          '${exam.subject} - ${exam.maxScore} درجة',
                          style: const TextStyle(
                            color: AppTheme.textSecondary,
                          ),
                        ),
                      ],
                    ),
                  ),
                  PopupMenuButton(
                    itemBuilder: (context) => [
                      const PopupMenuItem(
                        value: 'edit',
                        child: Row(
                          children: [
                            Icon(Icons.edit, size: 20),
                            SizedBox(width: 8),
                            Text('تعديل'),
                          ],
                        ),
                      ),
                      const PopupMenuItem(
                        value: 'delete',
                        child: Row(
                          children: [
                            Icon(Icons.delete, size: 20, color: AppTheme.errorColor),
                            SizedBox(width: 8),
                            Text('حذف', style: TextStyle(color: AppTheme.errorColor)),
                          ],
                        ),
                      ),
                    ],
                    onSelected: (value) {
                      if (value == 'edit') {
                        onEdit();
                      } else if (value == 'delete') {
                        onDelete();
                      }
                    },
                  ),
                ],
              ),
              const SizedBox(height: 12),
              Row(
                children: [
                  _InfoChip(
                    icon: Icons.calendar_today,
                    label: '${exam.examDate.day}/${exam.examDate.month}/${exam.examDate.year}',
                  ),
                  const SizedBox(width: 8),
                  _InfoChip(
                    icon: Icons.people,
                    label: '${exam.studentCount} طالب',
                  ),
                  const SizedBox(width: 8),
                  _InfoChip(
                    icon: Icons.assessment,
                    label: 'المعدل: ${exam.average.toStringAsFixed(1)}',
                  ),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }
}

class _StudentGradeCard extends StatelessWidget {
  final StudentModel student;
  final double average;
  final int gradesCount;
  final VoidCallback onTap;

  const _StudentGradeCard({
    required this.student,
    required this.average,
    required this.gradesCount,
    required this.onTap,
  });

  @override
  Widget build(BuildContext context) {
    Color averageColor = AppTheme.successColor;
    if (average < 60) {
      averageColor = AppTheme.errorColor;
    } else if (average < 75) {
      averageColor = AppTheme.warningColor;
    }

    return Card(
      margin: const EdgeInsets.only(bottom: 12),
      child: InkWell(
        onTap: onTap,
        borderRadius: BorderRadius.circular(16),
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Row(
            children: [
              CircleAvatar(
                radius: 30,
                backgroundColor: AppTheme.primaryColor.withOpacity(0.1),
                backgroundImage: student.photo != null ? NetworkImage(student.photo!) : null,
                child: student.photo == null
                    ? Text(
                        student.name.substring(0, 1).toUpperCase(),
                        style: TextStyle(
                          fontSize: 24,
                          fontWeight: FontWeight.bold,
                          color: AppTheme.primaryColor,
                        ),
                      )
                    : null,
              ),
              const SizedBox(width: 16),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      student.name,
                      style: const TextStyle(
                        fontSize: 18,
                        fontWeight: FontWeight.bold,
                      ),
                    ),
                    const SizedBox(height: 4),
                    Text(
                      'الرقم: ${student.studentId}',
                      style: const TextStyle(
                        color: AppTheme.textSecondary,
                      ),
                    ),
                  ],
                ),
              ),
              Column(
                crossAxisAlignment: CrossAxisAlignment.end,
                children: [
                  Text(
                    average.toStringAsFixed(1),
                    style: TextStyle(
                      fontSize: 24,
                      fontWeight: FontWeight.bold,
                      color: averageColor,
                    ),
                  ),
                  Text(
                    '$gradesCount اختبار',
                    style: const TextStyle(
                      fontSize: 12,
                      color: AppTheme.textSecondary,
                    ),
                  ),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }
}

