}

class _AddExamDialog extends StatefulWidget {
  final ClassModel classModel;
  final GradeModel? exam;
  final VoidCallback onSave;

  const _AddExamDialog({
    required this.classModel,
    this.exam,
    required this.onSave,
  });

  @override
  State<_AddExamDialog> createState() => _AddExamDialogState();
}

class _AddExamDialogState extends State<_AddExamDialog> {
  final _formKey = GlobalKey<FormState>();
  late final TextEditingController _examNameController;
  late final TextEditingController _subjectController;
  late final TextEditingController _maxScoreController;
  DateTime _selectedDate = DateTime.now();

  @override
  void initState() {
    super.initState();
    _examNameController = TextEditingController(text: widget.exam?.examName ?? '');
    _subjectController = TextEditingController(text: widget.exam?.subject ?? '');
    _maxScoreController = TextEditingController(text: widget.exam?.maxScore.toString() ?? '100');
    _selectedDate = widget.exam?.examDate ?? DateTime.now();
  }

  @override
  void dispose() {
    _examNameController.dispose();
    _subjectController.dispose();
    _maxScoreController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final isEditing = widget.exam != null;

    return AlertDialog(
      title: Text(isEditing ? 'تعديل الاختبار' : 'إضافة اختبار جديد'),
      content: SizedBox(
        width: double.maxFinite,
        child: Form(
          key: _formKey,
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              TextFormField(
                controller: _examNameController,
                decoration: const InputDecoration(
                  labelText: 'اسم الاختبار',
                  hintText: 'مثال: الاختبار الأول',
                ),
                validator: (value) {
                  if (value == null || value.isEmpty) {
                    return 'يرجى إدخال اسم الاختبار';
                  }
                  return null;
                },
              ),
              const SizedBox(height: 16),
              TextFormField(
                controller: _subjectController,
                decoration: const InputDecoration(
                  labelText: 'المادة',
                  hintText: 'مثال: الرياضيات',
                ),
                validator: (value) {
                  if (value == null || value.isEmpty) {
                    return 'يرجى إدخال المادة';
                  }
                  return null;
                },
              ),
              const SizedBox(height: 16),
              TextFormField(
                controller: _maxScoreController,
                decoration: const InputDecoration(
                  labelText: 'الدرجة القصوى',
                  hintText: 'مثال: 100',
                ),
                keyboardType: TextInputType.number,
                validator: (value) {
                  if (value == null || value.isEmpty) {
                    return 'يرجى إدخال الدرجة القصوى';
                  }
                  final score = double.tryParse(value);
                  if (score == null || score <= 0) {
                    return 'يرجى إدخال درجة صحيحة';
                  }
                  return null;
                },
              ),
              const SizedBox(height: 16),
              InkWell(
                onTap: () => _selectDate(context),
                child: Container(
                  padding: const EdgeInsets.all(12),
                  decoration: BoxDecoration(
                    border: Border.all(color: AppTheme.primaryColor),
                    borderRadius: BorderRadius.circular(8),
                  ),
                  child: Row(
                    children: [
                      Icon(Icons.calendar_today, color: AppTheme.primaryColor),
                      const SizedBox(width: 8),
                      Expanded(
                        child: Text(
                          'تاريخ الاختبار: ${_formatDate(_selectedDate)}',
                          style: const TextStyle(color: AppTheme.primaryColor),
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
      actions: [
        TextButton(
          onPressed: () => Navigator.pop(context),
          child: const Text('إلغاء'),
        ),
        Consumer<GradeProvider>(
          builder: (context, gradeProvider, child) {
            return ElevatedButton(
              onPressed: gradeProvider.isLoading ? null : () async {
                if (_formKey.currentState!.validate()) {
                  bool success;
                  
                  if (isEditing) {
                    success = await gradeProvider.updateExam(
                      widget.exam!.copyWith(
                        examName: _examNameController.text.trim(),
                        subject: _subjectController.text.trim(),
                        maxScore: double.parse(_maxScoreController.text.trim()),
                        examDate: _selectedDate,
                      ),
                    );
                  } else {
                    success = await gradeProvider.addExam(
                      _examNameController.text.trim(),
                      _subjectController.text.trim(),
                      double.parse(_maxScoreController.text.trim()),
                      _selectedDate,
                      widget.classModel.id!,
                    );
                  }

                  if (success && context.mounted) {
                    Navigator.pop(context);
                    widget.onSave();
                    ScaffoldMessenger.of(context).showSnackBar(
                      SnackBar(
                        content: Text(isEditing ? 'تم تحديث الاختبار بنجاح' : 'تم إضافة الاختبار بنجاح'),
                      ),
                    );
                  }
                }
              },
              child: gradeProvider.isLoading
                  ? const SizedBox(
                      width: 16,
                      height: 16,
                      child: CircularProgressIndicator(strokeWidth: 2),
                    )
                  : Text(isEditing ? 'تحديث' : 'إضافة'),
            );
          },
        ),
      ],
    );
  }

  Future<void> _selectDate(BuildContext context) async {
    final DateTime? picked = await showDatePicker(
      context: context,
      initialDate: _selectedDate,
      firstDate: DateTime.now(),
      lastDate: DateTime.now().add(const Duration(days: 365)),
    );
    if (picked != null && picked != _selectedDate) {
      setState(() {
        _selectedDate = picked;
      });
    }
  }

  String _formatDate(DateTime date) {
    return '${date.day}/${date.month}/${date.year}';
  }
}

class ExamDetailsScreen extends StatelessWidget {
  final GradeModel exam;
  final ClassModel classModel;

  const ExamDetailsScreen({
    super.key,
    required this.exam,
    required this.classModel,
  });

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text(exam.examName),
        actions: [
          IconButton(
            icon: const Icon(Icons.edit),
            onPressed: () => _showEditExamDialog(context),
          ),
        ],
      ),
      body: Consumer<GradeProvider>(
        builder: (context, gradeProvider, child) {
          final studentGrades = gradeProvider.getStudentGradesByExam(exam.id!);

          return Column(
            children: [
              // معلومات الاختبار
              Container(
                padding: const EdgeInsets.all(16),
                color: AppTheme.backgroundColor,
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      exam.examName,
                      style: const TextStyle(
                        fontSize: 24,
                        fontWeight: FontWeight.bold,
                      ),
                    ),
                    const SizedBox(height: 8),
                    Row(
                      children: [
                        _InfoItem(
                          icon: Icons.subject,
                          label: 'المادة',
                          value: exam.subject,
                        ),
                        const SizedBox(width: 16),
                        _InfoItem(
                          icon: Icons.assessment,
                          label: 'الدرجة القصوى',
                          value: exam.maxScore.toString(),
                        ),
                        const SizedBox(width: 16),
                        _InfoItem(
                          icon: Icons.calendar_today,
                          label: 'التاريخ',
                          value: '${exam.examDate.day}/${exam.examDate.month}/${exam.examDate.year}',
                        ),
                      ],
                    ),
                    const SizedBox(height: 12),
                    Row(
                      children: [
                        _InfoItem(
                          icon: Icons.people,
                          label: 'عدد الطلاب',
                          value: exam.studentCount.toString(),
                        ),
                        const SizedBox(width: 16),
                        _InfoItem(
                          icon: Icons.trending_up,
                          label: 'المعدل',
                          value: exam.average.toStringAsFixed(1),
                        ),
                        const SizedBox(width: 16),
                        _InfoItem(
                          icon: Icons.star,
                          label: 'أعلى درجة',
                          value: exam.highestScore.toString(),
                        ),
                      ],
                    ),
                  ],
                ),
              ),
              
              // درجات الطلاب
              Expanded(
                child: studentGrades.isEmpty
                    ? const Center(
                        child: Column(
                          mainAxisAlignment: MainAxisAlignment.center,
                          children: [
                            Icon(
                              Icons.grade,
                              size: 64,
                              color: AppTheme.textSecondary,
                            ),
                            SizedBox(height: 16),
                            Text(
                              'لا توجد درجات مسجلة',
                              style: TextStyle(
                                fontSize: 18,
                                color: AppTheme.textSecondary,
                              ),
                            ),
                          ],
                        ),
                      )
                    : ListView.builder(
                        padding: const EdgeInsets.all(16),
                        itemCount: studentGrades.length,
                        itemBuilder: (context, index) {
                          final grade = studentGrades[index];
                          return _StudentGradeItem(grade: grade, maxScore: exam.maxScore);
                        },
                      ),
              ),
            ],
          );
        },
      ),
      floatingActionButton: FloatingActionButton(
        onPressed: () => _showAddGradeDialog(context),
        child: const Icon(Icons.add),
      ),
    );
  }

  void _showEditExamDialog(BuildContext context) {
    showDialog(
      context: context,
      builder: (context) => _AddExamDialog(
        classModel: classModel,
        exam: exam,
        onSave: () {
          Provider.of<GradeProvider>(context, listen: false)
              .loadGradesByClass(classModel.id!);
        },
      ),
    );
  }

  void _showAddGradeDialog(BuildContext context) {
    showDialog(
      context: context,
      builder: (context) => _AddGradeDialog(
        exam: exam,
        classModel: classModel,
        onSave: () {
          Provider.of<GradeProvider>(context, listen: false)
              .loadGradesByClass(classModel.id!);
        },
      ),
    );
  }
}

class _InfoItem extends StatelessWidget {
