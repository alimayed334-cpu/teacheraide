# Telegram Bot Token from BotFather
BOT_TOKEN=

# Path to Firebase service account JSON (download from Firebase Console)
# Can be absolute path OR relative to this folder.
FIREBASE_SERVICE_ACCOUNT=serviceAccountKey.json

# Firestore collections/fields (change if your schema differs)
STUDENTS_COLLECTION=students
PARENTS_COLLECTION=parents
PHONE_FIELD=phone
CHAT_ID_FIELD=telegram_chat_id

# Phone normalization
# Example: 964 for Iraq, 966 for Saudi Arabia
COUNTRY_CODE=964
